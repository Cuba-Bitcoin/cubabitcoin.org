FROM nginx:alpine

# Install nginx for file watching (dev only)
RUN apk add --no-cache \
    openssl \
    bash \
    inotify-tools

# Create non-privileged user
RUN addgroup -g 1000 -S userapp && \
    adduser -u 1000 -S userapp -G userapp

# Create directories with proper permissions
RUN mkdir -p /usr/share/nginx/html /var/cache/nginx/client_temp && \
    chown -R userapp:userapp /usr/share/nginx/html /var/cache/nginx

# Copy nginx config
COPY --chown=userapp:userapp nginx-dev.conf /etc/nginx/conf.d/default.conf

WORKDIR /usr/share/nginx/html

# Expose port
EXPOSE 80

# Switch to non-privileged user
USER userapp

# Watch for file changes and reload nginx
CMD ["bash", "-c", "
    inotifywait -m -r -e modify,create,delete,move /usr/share/nginx/html &
    nginx -g 'daemon off;'
"]
